              "电性",
              "不带电",
              "带正电"
            ],
            [
              "最外层电子数",
              "1（不稳定）",
              "8（稳定）"
            ],
            [
              "化学性质",
              "活泼",
              "稳定"
            ]
          ]
        }
      ]
    }
  ],
  "examples": [
    {
      "title": "例1：化学符号的意义",
      "problem": [
        {
          "type": "paragraph",
          "content": "下列符号既能表示一个原子，又能表示一种元素，还能表示一种物质的是（ ）"
        },
        {
          "type": "list",
          "ordered": true,
          "items": [
            "A. O  B. Fe  C. 2H  D. H₂O"
          ]
        }
      ],
      "solution": [
        {
          "type": "list",
          "ordered": false,
          "items": [
            "A：O 能表示氧元素和一个氧原子，但不能表示一种物质（氧气是 O₂）",
            "B：Fe 能表示铁元素、一个铁原子、铁这种物质（铁由原子直接构成），三个意义都有 ✅",
            "C：2H 只表示2个氢原子，没有宏观意义",
            "D：H₂O 表示水、水由氢氧元素组成、一个水分子、水分子构成，但水由分子构成，不含\"一个原子\"的意义"
          ]
        },
        {
          "type": "paragraph",
          "content": "**答案**：B"
        }
      ],
      "answer": ""
    },
    {
      "title": "例2：粒子结构示意图判读",
      "problem": [
        {
          "type": "paragraph",
          "content": "某粒子的结构示意图为（+11）2 8，请回答：（1）该粒子含有________个质子，________个电子；（2）该粒子是________（填\"原子\"或\"离子\"），其符号为________。"
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "content": "（1）核电荷数（质子数）= 11，核外电子数 = 2 + 8 = 10（2）质子数(11) > 电子数(10)，带正电，为阳离子。质子数为11是钠元素，失去1个电子形成 Na⁺"
        },
        {
          "type": "paragraph",
          "content": "**答案**：11，10；阳离子，Na⁺"
        }
      ],
      "answer": ""
    }
  ],

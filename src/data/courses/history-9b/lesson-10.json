  "knowledge": [
    {
      "title": "美国经济发展",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "二战后，美国成为资本主义世界的霸主。20世纪50—70年代，美国经济持续发展，被称为「**黄金时代**」。70年代后，美国经济进入调整期。" },
        { "type": "callout", "variant": "note", "title": "补充说明", "content": "美国经济发展的原因包括：战后国际地位提高、第三次科技革命的推动、政府宏观调控等。" }
      ]
    },
    {
      "title": "欧洲联合与日本崛起",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "20世纪60年代，**欧洲共同体**成立，促进了西欧国家经济的发展和国际地位的提高。1993年，**欧盟**成立。日本在战后经济迅速恢复和发展，到20世纪60年代末成为资本主义世界第二经济大国。" },
        { "type": "callout", "variant": "tip", "title": "理解要点", "content": "欧洲联合和日本崛起冲击了美国的霸主地位，资本主义世界逐渐形成美、日、西欧三足鼎立的局面。" }
      ]
    }
  ],

  "examples": [
    {
      "title": "例1：学科名词用法",
      "problem": [
        { "type": "paragraph", "content": "My favorite subject is ___." },
        { "type": "list", "ordered": true, "items": ["A. a math", "B. math", "C. the math", "D. maths"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "学科名词前一般不加冠词，直接说 math 或 English。math 和 maths 都可以，但 B 选项格式更常见。答案选 B。" }
      ],
      "answer": "B"
    },
    {
      "title": "例2：职业描述",
      "problem": [
        { "type": "paragraph", "content": "My uncle works in a hospital. He is ___." },
        { "type": "list", "ordered": true, "items": ["A. a doctor", "B. doctor", "C. the doctor", "D. doctors"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "表示职业时，名词前用 a/an。He is a doctor 表示「他是一名医生」。答案选 A。" }
      ],
      "answer": "A"
    }
  ],

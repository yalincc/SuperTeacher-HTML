    {
      "title": "例1：学校设施词汇",
      "problem": [
        { "type": "paragraph", "content": "Where do you usually read books after class?" },
        { "type": "list", "ordered": true, "items": ["A. In the classroom", "B. In the library", "C. On the playground", "D. In the gym"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "read books（读书）通常在图书馆（library）进行。classroom（教室）、playground（操场）、gym（体育馆）不是读书的主要场所。答案选 B。" }
      ],
      "answer": "B"
    },
    {
      "title": "例2：校园生活短语",
      "problem": [
        { "type": "paragraph", "content": "She ___ the English speech contest and won the first prize." },
        { "type": "list", "ordered": true, "items": ["A. took part in", "B. took care of", "C. took the place of", "D. took up"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "根据句意「她参加了英语演讲比赛并获得一等奖」，take part in 意为「参加」，符合语境。take care of（照顾）、take the place of（代替）、take up（开始从事）都不符合。答案选 A。" }
      ],
      "answer": "A"
    }
  ],

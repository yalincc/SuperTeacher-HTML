            ["presentation", "/ˌpreznˈteɪʃn/", "n.", "展示；报告", "He gave a presentation in class."]
          ]
        },
        { "type": "callout", "variant": "warning", "title": "易错提醒", "content": "homework 是不可数名词，不能说 homeworks。exam 也可写成 examination（缩写）。" }

      "type": "choice",
      "id": "ex-14-01",
      "stem": "数据 $2, 3, 5, 5, 10$ 的平均数是（  ）",
      "options": [
        { "label": "A", "text": "3" },
        { "label": "B", "text": "4" },
        { "label": "C", "text": "5" },
        { "label": "D", "text": "6" }
      ],
      "answer": "C",
      "analysis": "平均数 $= \\frac{2 + 3 + 5 + 5 + 10}{5} = \\frac{25}{5} = 5$。"
    },

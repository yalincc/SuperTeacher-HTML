  "exercises": [
    {
      "type": "choice",
      "id": "ex-02-01",
      "stem": "下列各组数中，能构成直角三角形的是（  ）",
      "options": [
        { "label": "A", "text": "2, 3, 4" },
        { "label": "B", "text": "3, 4, 5" },
        { "label": "C", "text": "4, 5, 6" },
        { "label": "D", "text": "5, 6, 7" }
      ],
      "answer": "B",
      "analysis": "验证：$3^2 + 4^2 = 9 + 16 = 25 = 5^2$，满足勾股定理的逆定理，所以 3, 4, 5 构成直角三角形。"
    },
    {
      "type": "choice",
      "id": "ex-02-02",
      "stem": "三角形的三边长分别为 7、24、25，则这个三角形是（  ）",
      "options": [
        { "label": "A", "text": "锐角三角形" },
        { "label": "B", "text": "直角三角形" },
        { "label": "C", "text": "钝角三角形" },
        { "label": "D", "text": "无法确定" }
      ],
      "answer": "B",
      "analysis": "$7^2 + 24^2 = 49 + 576 = 625 = 25^2$，满足勾股定理逆定理，所以是直角三角形。"
    },
    {
      "type": "choice",
      "id": "ex-02-03",
      "stem": "一个三角形的三边长为 5、12、13，则这个三角形的面积为（  ）",
      "options": [
        { "label": "A", "text": "30" },
        { "label": "B", "text": "60" },
        { "label": "C", "text": "65" },
        { "label": "D", "text": "32.5" }
      ],
      "answer": "A",
      "analysis": "$5^2 + 12^2 = 25 + 144 = 169 = 13^2$，是直角三角形，两直角边为 5 和 12，面积 $= \\frac{1}{2} \\times 5 \\times 12 = 30$。"
    },
    {
      "type": "true_false",
      "id": "ex-02-04",
      "stem": "如果三角形的三边长满足 $a^2 + b^2 > c^2$（$c$ 为最长边），则该三角形一定是锐角三角形。",
      "answer": true,
      "analysis": "当 $a^2 + b^2 > c^2$ 时，三角形为锐角三角形；当 $a^2 + b^2 = c^2$ 时为直角三角形；当 $a^2 + b^2 < c^2$ 时为钝角三角形。"
    },
    {
      "type": "fill",
      "id": "ex-02-05",
      "segments": ["若三角形的三边长为 9、12、15，则该三角形___1___（填\\\"是\\\"或\\\"不是\\\"）直角三角形。"],
      "blanks": [
        { "index": 1, "answer": "是" }
      ],
      "analysis": "$9^2 + 12^2 = 81 + 144 = 225 = 15^2$，满足勾股定理逆定理，所以是直角三角形。"
    }
  ]
}

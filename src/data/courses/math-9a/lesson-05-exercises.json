  "lessonId": 5,
  "exercises": [
    {
      "type": "choice",
      "id": "ex-05-01",
      "stem": "用配方法解方程 $x^2 + 4x = 5$，应将其变形为（  ）",
      "options": [
        { "label": "A", "text": "$(x + 2)^2 = 5$" },
        { "label": "B", "text": "$(x + 2)^2 = 9$" },
        { "label": "C", "text": "$(x + 4)^2 = 5$" },
        { "label": "D", "text": "$(x + 4)^2 = 21$" }
      ],
      "answer": "B",
      "analysis": "配方需加上一次项系数一半的平方，即 $\\left(\\frac{4}{2}\\right)^2 = 4$。方程两边都加4得 $x^2 + 4x + 4 = 5 + 4$，即 $(x + 2)^2 = 9$。",
      "source": "2023年深圳中考"
    },
    {
      "type": "choice",
      "id": "ex-05-02",
      "stem": "方程 $x^2 - 6x + 5 = 0$ 的解为（  ）",
      "options": [
        { "label": "A", "text": "$x_1 = 1$，$x_2 = 5$" },
        { "label": "B", "text": "$x_1 = -1$，$x_2 = 5$" },
        { "label": "C", "text": "$x_1 = 1$，$x_2 = -5$" },
        { "label": "D", "text": "$x_1 = -1$，$x_2 = -5$" }
      ],
      "answer": "A",
      "analysis": "$x^2 - 6x + 5 = 0$，$(x - 3)^2 = 4$，$x - 3 = \\pm 2$，$x_1 = 5$，$x_2 = 1$。",
      "source": "2023年深圳中考"
    },
    {
      "type": "choice",
      "id": "ex-05-03",
      "stem": "用配方法解方程 $x^2 + 8x - 9 = 0$，正确的步骤是（  ）",
      "options": [
        { "label": "A", "text": "移项得 $x^2 + 8x = 9$，配方得 $(x + 4)^2 = 25$" },
        { "label": "B", "text": "移项得 $x^2 + 8x = 9$，配方得 $(x + 4)^2 = 9$" },
        { "label": "C", "text": "移项得 $x^2 - 8x = 9$，配方得 $(x - 4)^2 = 25$" },
        { "label": "D", "text": "移项得 $x^2 + 8x = 9$，配方得 $(x + 8)^2 = 73$" }
      ],
      "answer": "A",
      "analysis": "移项得 $x^2 + 8x = 9$，两边加 $\\left(\\frac{8}{2}\\right)^2 = 16$，得 $(x + 4)^2 = 25$。",
      "source": "2022年深圳中考"
    },
    {
      "type": "true_false",
      "id": "ex-05-04",
      "stem": "用配方法解方程 $x^2 + 2x - 3 = 0$，得到 $x_1 = 1$，$x_2 = -3$。",
      "answer": true,
      "analysis": "$x^2 + 2x = 3$，$(x + 1)^2 = 4$，$x + 1 = \\pm 2$，$x_1 = 1$，$x_2 = -3$。"
    },

  "knowledge": [
    {
      "title": "基数词 Cardinal Numbers",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "**基数词**表示数量，1-100 的拼写需要特别注意以下易错词：" },
        {
          "type": "table",
          "headers": ["数字", "拼写", "易错点"],
          "rows": [
            ["13", "thirteen", "注意 -teen 结尾"],
            ["15", "fifteen", "five→fif，不是 fiveteen"],
            ["18", "eighteen", "eight 已有 t，只加 een"],
            ["20", "twenty", "注意 -ty 结尾"],
            ["30", "thirty", "注意 -ty 结尾"]
          ]
        },
        { "type": "callout", "variant": "tip", "title": "记忆技巧", "content": "13-19 以 -teen 结尾，20-90 以 -ty 结尾。fifteen 和 fifty 都来自 five。" }
      ]
    },
    {
      "title": "序数词 Ordinal Numbers",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "**序数词**表示顺序，构成规则如下：" },
        {
          "type": "table",
          "headers": ["规则", "变化方式", "例词"],
          "rows": [
            ["一般情况", "加 -th", "fourth, sixth, seventh"],
            ["特殊变化", "不规则", "first, second, third"],
            ["以 e 结尾", "直接加 -th", "ninth, fifth"],
            ["以 y 结尾", "变 y 为 i 加 -eth", "twentieth, thirtieth"],
            ["以 ve 结尾", "变 ve 为 f 加 -th", "fifth, twelfth"]
          ]
        },
        { "type": "callout", "variant": "warning", "title": "易错提醒", "content": "first, second, third 是不规则变化，必须单独记忆。nine→ninth（去掉 e），five→fifth（变 ve 为 f）。" }
      ]
    },
    {
      "title": "数字的用法",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "数字在英语中常用于编号、年份和分数表达：" },
        {
          "type": "table",
          "headers": ["用法", "表达方式", "例句"],
          "rows": [
            ["编号", "用序数词或基数词", "the third floor / Room 305"],
            ["年份", "基数词读出", "1999 → nineteen ninety-nine"],
            ["分数", "序数词（分子大于1加复数）", "1/3 → one third, 2/3 → two thirds"]
          ]
        },
        { "type": "callout", "variant": "mnemonic", "title": "记忆口诀", "content": "编号用序数，年份用基数，分数分子基分母序。" }
      ]
    }
  ],
  "examples": [
    {
      "title": "例1：基数词拼写",
      "problem": [
        { "type": "paragraph", "content": "Which is the correct spelling of 15?" },
        { "type": "list", "ordered": true, "items": ["A. fiveteen", "B. fifteen", "C. fiftteen", "D. fiften"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "fifteen 来自 five，five→fif + teen = fifteen。注意不是 fiveteen 或 fiftteen。答案选 B。" }
      ],
      "answer": "B"
    },
    {
      "title": "例2：序数词构成",
      "problem": [
        { "type": "paragraph", "content": "What is the ordinal number of 21?" },
        { "type": "list", "ordered": true, "items": ["A. twenty-first", "B. twentieth-first", "C. twenty-oneth", "D. twenty-ones"] }
      ],
      "solution": [
        { "type": "paragraph", "content": "21 的序数词是 twenty-first，基数词 twenty + 序数词 first。答案选 A。" }
      ],
      "answer": "A"
    }
  ],

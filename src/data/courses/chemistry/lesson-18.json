        { "type": "list", "ordered": false, "items": ["太阳能", "风能", "核能", "地热能", "潮汐能", "氢能（最清洁）"] },
        { "type": "callout", "variant": "tip", "title": "解题技巧", "content": "氢能被认为是最理想的新能源：来源广（水分解）、热值高、产物是水无污染。" }
      ]

  "knowledge": [
    {
      "title": "实验室制取CO₂",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "**药品**：大理石（或石灰石，主要成分CaCO₃）和稀盐酸。" },
        { "type": "equation", "latex": "CaCO_3 + 2HCl = CaCl_2 + H_2O + CO_2\\uparrow", "display": true },
        { "type": "callout", "variant": "warning", "title": "易错提醒", "content": "不用稀硫酸：生成的CaSO₄微溶，覆盖在大理石表面阻止反应。不用浓盐酸：挥发HCl气体使CO₂不纯。不用Na₂CO₃：反应太快不易控制。" }
      ]
    },
    {
      "title": "发生装置和收集装置",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "**发生装置**：固液常温型（与H₂O₂制O₂相同）。**收集装置**：向上排空气法（CO₂密度大于空气，能溶于水，不能用排水法）。" },
        { "type": "callout", "variant": "tip", "title": "解题技巧", "content": "检验CO₂是否收集满：将燃着的木条放在集气瓶口，木条熄灭则满。验满用瓶口，检验用澄清石灰水。" }
      ]
    },
    {
      "title": "CO₂和O₂制法对比",
      "defaultExpanded": true,
      "blocks": [
        { "type": "table", "headers": ["对比项", "制O₂", "制CO₂"], "rows": [["药品", "H₂O₂+MnO₂或KMnO₄", "大理石+稀盐酸"], ["发生装置", "固液常温或固体加热", "固液常温"], ["收集方法", "排水法或向上排空气法", "向上排空气法"], ["验满方法", "带火星木条放瓶口", "燃着木条放瓶口"]] }
      ]
    }
  ],
  "examples": [
    {
      "title": "例1：制取CO₂药品选择",
      "problem": [{ "type": "paragraph", "content": "实验室制取CO₂不选用稀硫酸的原因是（  ）" }, { "type": "list", "ordered": true, "items": ["A. 反应太慢", "B. 生成的CaSO₄微溶阻止反应", "C. 不产生CO₂", "D. 价格太贵"] }],
      "solution": [{ "type": "paragraph", "content": "稀硫酸与CaCO₃反应生成CaSO₄微溶物覆盖在大理石表面，阻止反应继续。" }],
      "answer": "B"
    }
  ],

  "objectives": [
    { "text": "理解幂的乘方法则的推导过程", "isKeyPoint": true },
    { "text": "掌握幂的乘方法则：$(a^m)^n = a^{mn}$", "isKeyPoint": true },
    { "text": "掌握积的乘方法则：$(ab)^n = a^n b^n$", "isKeyPoint": true },
    { "text": "能综合运用幂的乘方与积的乘方法则进行运算", "isKeyPoint": false },

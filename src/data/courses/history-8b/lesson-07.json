  "knowledge": [
    {
      "title": "文化大革命的发动",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "1966年5月，**文化大革命**全面发动。这场运动由领导者错误发动，被反革命集团利用，给党、国家和各族人民带来了建国以来最严重的挫折和损失。1976年10月，粉碎「**四人帮**」，文化大革命结束。" },
        { "type": "timeline", "items": [
          { "time": "1966年", "title": "文革发动", "content": "文化大革命全面发动" },
          { "time": "1976年10月", "title": "文革结束", "content": "粉碎「四人帮」" }
        ]},
        { "type": "callout", "variant": "warning", "title": "易错提醒", "content": "文化大革命不是任何意义上的革命或社会进步，而是一场由领导者错误发动、被反革命集团利用的内乱。" }
      ]
    },
    {
      "title": "文化大革命的危害",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "文化大革命期间，民主与法制遭到严重破坏，大批干部和知识分子受到迫害，国民经济遭受严重损失。**刘少奇**被迫害致死，是文革中最大的冤案。" },
        { "type": "callout", "variant": "tip", "title": "经验教训", "content": "文化大革命的教训：必须坚持以经济建设为中心，加强社会主义民主法制建设，反对任何形式的个人崇拜。" }
      ]
    }
  ],

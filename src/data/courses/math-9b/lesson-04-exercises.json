    {
      "type": "choice",
      "id": "ex-04-01",
      "stem": "下列函数中，是二次函数的是（  ）",
      "options": [
        { "label": "A", "text": "$y = x^2 + \\frac{1}{x}$" },
        { "label": "B", "text": "$y = 2x + 1$" },
        { "label": "C", "text": "$y = (x - 1)^2$" },
        { "label": "D", "text": "$y = x^3 + 1$" }
      ],
      "answer": "C",
      "analysis": "A 含 $\\frac{1}{x}$ 不是整式；B 是一次函数；D 最高次数为 $3$。C 展开为 $y = x^2 - 2x + 1$，符合二次函数定义。",
      "source": "2023年深圳中考"
    },
    {
      "type": "choice",
      "id": "ex-04-02",
      "stem": "若函数 $y = (m - 1)x^{m^2 + 1}$ 是二次函数，则 $m$ 的值为（  ）",
      "options": [
        { "label": "A", "text": "$1$" },
        { "label": "B", "text": "$-1$" },
        { "label": "C", "text": "$\\pm 1$" },
        { "label": "D", "text": "$2$" }
      ],
      "answer": "B",
      "analysis": "由题意，$m^2 + 1 = 2$ 且 $m - 1 \\neq 0$。$m^2 = 1$，$m = \\pm 1$。又 $m - 1 \\neq 0$，所以 $m \\neq 1$，故 $m = -1$。",
      "source": "2022年深圳中考"
    },

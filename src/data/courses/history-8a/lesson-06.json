  "knowledge": [
    {
      "title": "孙中山与革命准备",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "**孙中山**是中国民主革命的先行者。1905年，他在日本东京成立**中国同盟会**，提出「**三民主义**」（民族、民权、民生）。革命党人发动了多次武装起义。" },
        { "type": "callout", "variant": "note", "title": "三民主义", "content": "民族主义：推翻清朝统治；民权主义：建立民国；民生主义：平均地权。三民主义是辛亥革命的指导思想。" }
      ]
    },
    {
      "title": "辛亥革命",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "1911年10月10日，革命党人在**武昌**发动起义，史称「**辛亥革命**」。1912年1月1日，**中华民国**成立，孙中山任临时大总统。同年2月，清宣统帝退位，清朝灭亡。" },
        { "type": "timeline", "items": [
          { "time": "1911年10月10日", "title": "武昌起义", "content": "辛亥革命爆发" },
          { "time": "1912年1月1日", "title": "中华民国成立", "content": "孙中山任临时大总统" },
          { "time": "1912年2月", "title": "清朝灭亡", "content": "宣统帝退位" }
        ]},
        { "type": "callout", "variant": "tip", "title": "历史意义", "content": "辛亥革命推翻了清王朝的反动统治，结束了中国两千多年的君主专制制度，使民主共和观念深入人心。" }
      ]
    }
  ],

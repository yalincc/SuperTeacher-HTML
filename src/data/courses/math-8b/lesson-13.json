    { "text": "理解平行四边形的定义：两组对边分别平行的四边形", "isKeyPoint": true },
    { "text": "掌握平行四边形的性质：对边相等、对角相等、对角线互相平分", "isKeyPoint": true },
    { "text": "能利用平行四边形的性质进行计算和证明", "isKeyPoint": true },
    { "text": "了解平行四边形的面积公式", "isKeyPoint": false },

    {
      "type": "choice",
      "id": "ex-05-01",
      "stem": "计算 $(-6)+(-3)$ 的结果是（  ）",
      "options": [
        { "label": "A", "text": "$9$" },
        { "label": "B", "text": "$-9$" },
        { "label": "C", "text": "$3$" },
        { "label": "D", "text": "$-3$" }
      ],
      "answer": "B",
      "analysis": "同号两数相加，取负号，绝对值相加：$(-6)+(-3)=-(6+3)=-9$。"
    },
    {
      "type": "choice",
      "id": "ex-05-02",
      "stem": "计算 $5-(-3)$ 的结果是（  ）",
      "options": [
        { "label": "A", "text": "$2$" },
        { "label": "B", "text": "$8$" },
        { "label": "C", "text": "$-8$" },
        { "label": "D", "text": "$-2$" }
      ],
      "answer": "B",
      "analysis": "减去一个数等于加上它的相反数：$5-(-3)=5+3=8$。"
    },
    {
      "type": "choice",
      "id": "ex-05-03",
      "stem": "计算 $(-2)+7-(-3)$ 的结果是（  ）",
      "options": [
        { "label": "A", "text": "$8$" },
        { "label": "B", "text": "$-8$" },
        { "label": "C", "text": "$2$" },
        { "label": "D", "text": "$-2$" }
      ],
      "answer": "A",
      "analysis": "先将减法变加法：$(-2)+7+3=(-2)+[7+3]=(-2)+10=8$。"
    },

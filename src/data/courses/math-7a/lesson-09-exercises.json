      "segments": ["去括号：$-(a - b + c) =$", "___1___", "。"],
      "blanks": [{ "index": 1, "answer": "$-a + b - c$" }],
      "analysis": "括号前是负号，去括号后各项符号都要改变，所以 $-(a - b + c) = -a + b - c$。"
    }
  ]

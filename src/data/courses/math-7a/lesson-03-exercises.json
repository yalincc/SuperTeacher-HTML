  "exercises": [
    {
      "type": "choice",
      "id": "ex-03-01",
      "stem": "下列各数中，是负数的是（  ）",
      "options": [
        { "label": "A", "text": "$0$" },
        { "label": "B", "text": "$-(-3)$" },
        { "label": "C", "text": "$-\\frac{1}{2}$" },
        { "label": "D", "text": "$|2|$" }
      ],
      "answer": "C",
      "analysis": "$0$ 既不是正数也不是负数；$-(-3)=3$ 是正数；$|2|=2$ 是正数；只有 $-\\frac{1}{2}$ 是负数。"
    },
    {
      "type": "choice",
      "id": "ex-03-02",
      "stem": "$-3$ 的相反数和绝对值分别是（  ）",
      "options": [
        { "label": "A", "text": "$3$ 和 $3$" },
        { "label": "B", "text": "$-3$ 和 $3$" },
        { "label": "C", "text": "$3$ 和 $-3$" },
        { "label": "D", "text": "$-3$ 和 $-3$" }
      ],
      "answer": "A",
      "analysis": "$-3$ 的相反数是 $3$（改变符号）；$-3$ 的绝对值是 $|-3|=3$（到原点的距离）。"
    },
    {
      "type": "choice",
      "id": "ex-03-03",
      "stem": "下列说法中，正确的是（  ）",
      "options": [
        { "label": "A", "text": "有理数包括正数和负数" },
        { "label": "B", "text": "所有整数都是有理数" },
        { "label": "C", "text": "绝对值等于它本身的数只有正数" },
        { "label": "D", "text": "$-a$ 一定是负数" }
      ],
      "answer": "B",
      "analysis": "A 错误，$0$ 既不是正数也不是负数，但也属于有理数；B 正确，整数和分数统称有理数；C 错误，$0$ 的绝对值等于它本身；D 错误，当 $a$ 为负数时，$-a$ 是正数。"
    },
    {
      "type": "true_false",
      "id": "ex-03-04",
      "stem": "一个数的绝对值一定是正数。",
      "answer": false,
      "analysis": "错误。$0$ 的绝对值是 $0$，$0$ 不是正数。正确说法是\"一个数的绝对值一定是非负数\"。"
    },

      "id": "ex-13-04",
      "segments": ["若 $x=2$ 是方程 $3x-a=4$ 的解，则 $a$ 的值为___1___。"],
      "blanks": [
        { "index": 1, "answer": "2" }
      ],
      "analysis": "把 $x=2$ 代入方程 $3x-a=4$，得 $3\\times2-a=4$，即 $6-a=4$，解得 $a=2$。"

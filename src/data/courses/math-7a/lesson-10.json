  "knowledge": [
    {
      "title": "线段、射线、直线的概念",
      "defaultExpanded": true,
      "blocks": [
        { "type": "paragraph", "content": "线段：直线上两点间的部分，有两个端点，长度可以度量。" },
        { "type": "paragraph", "content": "射线：直线上的一点和它一旁的部分，有一个端点，向一方无限延伸，长度不可度量。" },
        { "type": "paragraph", "content": "直线：没有端点，向两方无限延伸，长度不可度量。" },
        { "type": "callout", "variant": "tip", "title": "区别要点", "content": "端点个数：线段有2个，射线有1个，直线没有。延伸性：线段不延伸，射线向一方延伸，直线向两方延伸。" },
        {
          "type": "figure",
          "figure": {
            "type": "construction",
            "construction": [
              { "op": "point", "id": "A", "at": [0, 4] },
              { "op": "point", "id": "B", "at": [3, 4] },
              { "op": "segment", "from": "A", "to": "B" },
              { "op": "label", "at": [-0.3, 4.5], "text": "A" },
              { "op": "label", "at": [3.3, 4.5], "text": "B" },
